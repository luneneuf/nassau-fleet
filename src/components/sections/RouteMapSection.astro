---
import RouteMap from '../interactive/RouteMap.jsx';
---
<section id="route" style="background: var(--surface-container-lowest);">
  <div class="container">
    <div class="section-header">
      <p class="section-eyebrow">VOYAGE ROUTE · 1623 — 1626</p>
      <h2 class="section-title">항로 재현</h2>
      <p class="section-desc">
        고레에서 출항해 희망봉을 돌아 태평양을 횡단한 뒤 바타비아에서 귀환한 3년간의 항적.
      </p>
    </div>
    <RouteMap client:visible />
  </div>
</section>

---
import StatCard from '../StatCard.astro';
import ShipTracker from '../interactive/ShipTracker.jsx';
import SurvivalChart from '../interactive/SurvivalChart.jsx';
---
<section id="fleet" style="background: var(--surface);">
  <div class="container">
    <div class="section-header">
      <p class="section-eyebrow">ORDER OF BATTLE</p>
      <h2 class="section-title">나사우 함대 편성</h2>
      <p class="section-desc">
        자크 르 에르미트 제독이 이끈 11척의 함대.
        네덜란드 의회와 VOC가 공동 기획한 태평양 원정의 전모.
        계획은 1619년부터 시작됐고, 4년의 준비 끝에 출항했다.
      </p>
    </div>

    <div class="stats-grid">
      <StatCard label="출항일" value="1623.04.29" note="고레(Gorée) 항 출발" />
      <StatCard label="함선" value="11척" note="기함 암스테르담호" />
      <StatCard label="병력" value="1,600명" note="수병 + 육전대" />
      <StatCard label="칼라오 봉쇄" value="98일" note="1624.05.08 — 08.14" />
    </div>

    <SurvivalChart client:visible />

    <div class="fleet-split">
      <div class="fleet-list">
        <div class="fleet-list-header">
          <span>함선명</span>
          <span>규모</span>
          <span>포문</span>
          <span>비고</span>
        </div>
        <div class="fleet-row">
          <span class="ship-name">Amsterdam</span>
          <span>—</span>
          <span>42문</span>
          <span class="ship-note">기함 · 르 에르미트 승함</span>
        </div>
        <div class="fleet-row">
          <span class="ship-name">Leiden</span>
          <span>—</span>
          <span>—</span>
          <span class="ship-note">원정 일지에서 확인</span>
        </div>
        <div class="fleet-row">
          <span class="ship-name">기타 9척</span>
          <span>—</span>
          <span>—</span>
          <span class="ship-note">함명 기록 불완전</span>
        </div>
      </div>

      <div class="fleet-visual">
        <div class="pixel-frame pixel-frame--wide">
          <img src="/pixel/fleet-formation.png" alt="나사우 함대 편대 항해 — 1623년 출항" />
        </div>
        <p class="hero-caption">1623년 4월 29일 — 고레 항을 떠나는 나사우 함대</p>
      </div>
    </div>

    <ShipTracker client:visible />
  </div>
</section>

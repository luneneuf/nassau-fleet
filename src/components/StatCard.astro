---
interface Props {
  label: string;
  value: string;
  note?: string;
}
const { label, value, note } = Astro.props;
---
<div class="stat-card">
  <span class="stat-label">{label}</span>
  <span class="stat-value">{value}</span>
  {note && <span class="stat-note">{note}</span>}
</div>

<style>
  .stat-card {
    background: var(--surface-container);
    padding: 24px 28px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .stat-label {
    font-family: var(--font-meta);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--secondary);
  }
  .stat-value {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--primary);
    line-height: 1;
  }
  .stat-note {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--on-surface);
    opacity: 0.7;
    font-style: italic;
  }
</style>
